<Window x:Class="BimPrefabExport.UI.BimPrefabPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:BimPrefabExport.UI"
        Title="BIM Prefab"
        Height="820"
        Width="980"
        MinHeight="480"
        MinWidth="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F3F6F9">
  <Window.Resources>
    <Style x:Key="CenterCheckStyle" TargetType="CheckBox">
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <ui:NullableDoubleConverter x:Key="NullableDoubleConverter" />
  </Window.Resources>
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" MinHeight="320" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="BIM Prefab — solda ürün listesi, sağda Genel / Tipoloji / Malzemeler / Donatılar"
               TextWrapping="Wrap"
               Margin="0,0,0,8"
               FontSize="14"
               FontWeight="SemiBold"
               Foreground="#123A5C" />

    <WrapPanel x:Name="ToolbarPanel"
               Grid.Row="1"
               Margin="0,0,0,8" />

    <Grid Grid.Row="2" Margin="0,0,0,6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="280" MinWidth="220" />
        <ColumnDefinition Width="12" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Sol: liste -->
      <DockPanel Grid.Column="0" LastChildFill="True">
        <CheckBox x:Name="SelectAllProductsCheck"
                  DockPanel.Dock="Top"
                  Margin="0,0,0,6"
                  Content="Tümünü işaretle (CSV / paket)"
                  IsThreeState="True"
                  Click="OnSelectAllProductsClick" />
        <DataGrid x:Name="ProductGrid"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeight="30"
                  BorderBrush="#C8D0D8"
                  BorderThickness="1"
                  Background="White"
                  FontSize="13"
                  AlternationCount="2"
                  AlternatingRowBackground="#F8FAFC"
                  SelectionChanged="OnProductGridSelectionChanged">
          <DataGrid.Columns>
            <DataGridCheckBoxColumn Header="✓"
                                    Width="40"
                                    Binding="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    ElementStyle="{StaticResource CenterCheckStyle}" />
            <DataGridTextColumn Header="Ürün"
                                Binding="{Binding Record.DisplayName, Mode=OneWay}"
                                Width="*"
                                MinWidth="72"
                                IsReadOnly="True" />
            <DataGridTextColumn Header="Kod"
                                Binding="{Binding Record.Code, Mode=OneWay}"
                                Width="72"
                                IsReadOnly="True" />
            <DataGridTextColumn Header="Rev"
                                Binding="{Binding Record.Revision, Mode=OneWay}"
                                Width="36"
                                IsReadOnly="True" />
          </DataGrid.Columns>
        </DataGrid>
      </DockPanel>

      <!-- Sağ: ürün aksiyonları + sekmeler -->
      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="0,0,0,8"
                Margin="0,0,0,6"
                BorderThickness="0,0,0,1"
                BorderBrush="#C8D0D8">
          <WrapPanel x:Name="ProductActionPanel" />
        </Border>

        <TabControl x:Name="DetailTabs"
                    Grid.Row="1"
                    Background="White"
                    BorderBrush="#C8D0D8"
                    BorderThickness="1"
                    Padding="6"
                    SelectionChanged="OnDetailTabsSelectionChanged">
          <TabItem Header="Genel">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="120" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Görünen ad" VerticalAlignment="Center" Margin="0,6" />
                <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="1" Margin="0,4" VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Kod" VerticalAlignment="Center" Margin="0,6" />
                <TextBox x:Name="CodeBox" Grid.Row="1" Grid.Column="1" Margin="0,4" VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Adet" VerticalAlignment="Center" Margin="0,6" />
                <TextBox x:Name="QtyBox" Grid.Row="2" Grid.Column="1" Margin="0,4" VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Revizyon" VerticalAlignment="Center" Margin="0,6" />
                <TextBox x:Name="RevisionBox" Grid.Row="3" Grid.Column="1" Margin="0,4" VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Not" VerticalAlignment="Center" Margin="0,6" />
                <TextBox x:Name="NoteBox" Grid.Row="4" Grid.Column="1" Margin="0,4" VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Text="PDF çizimleri (her çit alanı — ayrı PDF)"
                           FontWeight="SemiBold"
                           Foreground="#123A5C"
                           Margin="0,12,0,4" />

                <TextBlock Grid.Row="6"
                           Grid.Column="0"
                           Text="Çizim seç"
                           VerticalAlignment="Top"
                           Margin="0,6,8,0" />
                <Grid Grid.Row="6"
                      Grid.Column="1"
                      Margin="0,4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <ListBox x:Name="PdfDrawingsList"
                           Grid.Column="0"
                           MinHeight="100"
                           MaxHeight="160"
                           SelectionChanged="OnPdfDrawingsListSelectionChanged" />
                  <Button x:Name="RemovePdfDrawingButton"
                          Grid.Column="1"
                          Content="Çizimi sil"
                          MinWidth="108"
                          Margin="8,0,0,0"
                          Padding="10,4"
                          VerticalAlignment="Top"
                          Click="OnRemovePdfDrawingClick" />
                </Grid>

                <TextBlock Grid.Row="7"
                           Grid.Column="0"
                           Text="PDF çizim adı"
                           VerticalAlignment="Center"
                           Margin="0,6"
                           ToolTip="Dosya adı: kod_çizimAdı.pdf; PDF çizim rev. &gt; 0 ise sonuna _r{n} eklenir." />
                <StackPanel Grid.Row="7" Grid.Column="1" Margin="0,4">
                  <TextBox x:Name="PdfDrawingTitleBox"
                           VerticalContentAlignment="Center"
                           TextChanged="OnPdfDrawingTitleBoxTextChanged" />
                  <TextBlock x:Name="PdfDrawingExportInfoText"
                             Margin="0,4,0,0"
                             FontSize="11"
                             Foreground="#5A6570"
                             TextWrapping="Wrap"
                             Text="" />
                </StackPanel>

                <TextBlock Grid.Row="8"
                           Grid.Column="0"
                           Text="PDF çizim rev."
                           VerticalAlignment="Center"
                           Margin="0,6"
                           ToolTip="Tam sayı ≥ 0. &gt; 0 olduğunda dışa aktarılan dosya adına _r{n} eklenir (aynı çizim adıyla sürüm ayırımı)." />
                <TextBox x:Name="PdfDrawingRevisionBox"
                         Grid.Row="8"
                         Grid.Column="1"
                         Margin="0,4"
                         VerticalContentAlignment="Center"
                         LostFocus="OnPdfDrawingRevisionBoxLostFocus" />

                <TextBlock Grid.Row="9"
                           Grid.Column="0"
                           Text="PDF kağıt"
                           VerticalAlignment="Center"
                           Margin="0,6"
                           ToolTip="Seçili çizim alanı için kağıt boyutu." />
                <ComboBox x:Name="PaperSizeCombo"
                          Grid.Row="9"
                          Grid.Column="1"
                          Margin="0,4"
                          VerticalContentAlignment="Center"
                          IsEditable="False"
                          SelectionChanged="OnPdfDrawingPaperSizeChanged" />

                <StackPanel Grid.Row="10"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            Margin="0,4,0,8">
                  <TextBlock Text="PDF yönü (seçili çizim):"
                             VerticalAlignment="Center"
                             Margin="0,0,12,0" />
                  <RadioButton x:Name="PlotOrientationPortraitRadio"
                               Content="Dikey (portrait)"
                               GroupName="PrefPlotOrient"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center"
                               Checked="OnPlotOrientationChanged" />
                  <RadioButton x:Name="PlotOrientationLandscapeRadio"
                               Content="Yatay (landscape)"
                               GroupName="PrefPlotOrient"
                               VerticalAlignment="Center"
                               Checked="OnPlotOrientationChanged" />
                </StackPanel>

                <TextBlock Grid.Row="11"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Text="Çizim sınırı önizlemesi (seçili çit)"
                           FontWeight="SemiBold"
                           Foreground="#123A5C"
                           Margin="0,8,0,4" />

                <Border x:Name="LinkFencePreviewHost"
                        Grid.Row="12"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        MinHeight="168"
                        Height="200"
                        Background="#F0F4F8"
                        BorderBrush="#C8D0D8"
                        BorderThickness="1"
                        CornerRadius="4"
                        ClipToBounds="True"
                        SizeChanged="OnLinkFencePreviewHostSizeChanged">
                  <Grid>
                    <Canvas x:Name="LinkFencePreviewCanvas"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch" />
                    <TextBlock x:Name="FencePreviewOverlayText"
                               Margin="12"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="#5A6570"
                               FontSize="12"
                               Text="Ürün seçildiğinde kayıtlı çitler burada görünür."
                               IsHitTestVisible="False" />
                  </Grid>
                </Border>

                <TextBlock x:Name="FencePreviewCaptionText"
                           Grid.Row="13"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Margin="0,6,0,0"
                           FontSize="11"
                           Foreground="#5A6570"
                           TextWrapping="Wrap"
                           Text="" />
              </Grid>
            </ScrollViewer>
          </TabItem>

        <TabItem Header="Tipoloji">
          <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8">
            <StackPanel>
              <TextBlock Text="Katalog (categories.json): eleman tipi ve tipoloji."
                         FontWeight="SemiBold"
                         Foreground="#123A5C"
                         Margin="0,0,0,8"
                         TextWrapping="Wrap" />

              <TextBlock Text="Kategori" FontWeight="SemiBold" Margin="0,0,0,4" />
              <ComboBox x:Name="PaletteCategoryCombo"
                        DisplayMemberPath="DisplayName"
                        Margin="0,0,0,8"
                        VerticalContentAlignment="Center"
                        IsEditable="False"
                        SelectionChanged="OnPaletteCategoryComboSelectionChanged" />

              <TextBlock Text="Eleman tipi" FontWeight="SemiBold" Margin="0,0,0,4" />
              <ComboBox x:Name="PaletteElementTypeCombo"
                        DisplayMemberPath="DisplayName"
                        Margin="0,0,0,8"
                        VerticalContentAlignment="Center"
                        IsEditable="False"
                        SelectionChanged="OnPaletteElementTypeComboSelectionChanged" />

              <TextBlock Text="Tipoloji" FontWeight="SemiBold" Margin="0,0,0,4" />
              <ComboBox x:Name="PaletteTypologyCombo"
                        DisplayMemberPath="DisplayName"
                        Margin="0,0,0,12"
                        VerticalContentAlignment="Center"
                        IsEditable="False"
                        SelectionChanged="OnPaletteTypologyComboSelectionChanged" />

              <DataGrid x:Name="PaletteDimGrid"
                        Height="320"
                        MinHeight="160"
                        Margin="0,0,0,0"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        HeadersVisibility="Column"
                        GridLinesVisibility="Horizontal"
                        BorderBrush="#D8DEE6"
                        BorderThickness="1"
                        Background="White" />
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Malzemeler">
          <Grid Margin="4">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
              <Button Content="CSV'den yükle…"
                      MinWidth="132"
                      Margin="0,0,8,0"
                      Padding="10,4"
                      Click="OnImportMaterialsCsv" />
              <Button Content="CSV indir…"
                      MinWidth="112"
                      Margin="0,0,8,0"
                      Padding="10,4"
                      Click="OnExportMaterialsCsv" />
              <Button Content="+ Satır"
                      Width="88"
                      Margin="0,0,8,0"
                      Padding="8,4"
                      Click="OnAddMaterialRow" />
              <Button Content="− Satır"
                      Width="88"
                      Padding="8,4"
                      Click="OnRemoveMaterialRow" />
            </StackPanel>
            <DataGrid x:Name="MaterialsGrid"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      BorderBrush="#C8D0D8"
                      BorderThickness="1"
                      Background="White">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Kategori"
                                    Binding="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*" MinWidth="72" />
                <DataGridTextColumn Header="Kod"
                                    Binding="{Binding Code, UpdateSourceTrigger=PropertyChanged}"
                                    Width="80" />
                <DataGridTextColumn Header="Katalog kodu"
                                    Binding="{Binding MaterialCatalogCode, UpdateSourceTrigger=PropertyChanged}"
                                    Width="96" />
                <DataGridTextColumn Header="Açıklama"
                                    Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                    Width="2*" MinWidth="80" />
                <DataGridTextColumn Header="Miktar"
                                    Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                    Width="72" />
                <DataGridTextColumn Header="Birim"
                                    Binding="{Binding Unit, UpdateSourceTrigger=PropertyChanged}"
                                    Width="56" />
                <DataGridTextColumn Header="Not"
                                    Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*" MinWidth="50" />
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </TabItem>

        <TabItem Header="Donatılar">
          <Grid Margin="4">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
              <Button Content="CSV'den yükle…"
                      MinWidth="132"
                      Margin="0,0,8,0"
                      Padding="10,4"
                      Click="OnImportRebarsCsv" />
              <Button Content="CSV indir…"
                      MinWidth="112"
                      Margin="0,0,8,0"
                      Padding="10,4"
                      Click="OnExportRebarsCsv" />
              <Button Content="+ Satır"
                      Width="88"
                      Margin="0,0,8,0"
                      Padding="8,4"
                      Click="OnAddRebarRow" />
              <Button Content="− Satır"
                      Width="88"
                      Padding="8,4"
                      Click="OnRemoveRebarRow" />
            </StackPanel>
            <DataGrid x:Name="RebarsGrid"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      BorderBrush="#C8D0D8"
                      BorderThickness="1"
                      Background="White">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Poz"
                                    Binding="{Binding PozNo, UpdateSourceTrigger=PropertyChanged}"
                                    Width="48"
                                    IsReadOnly="True" />
                <DataGridTextColumn Header="Çap (mm)"
                                    Binding="{Binding DiameterMm, Converter={StaticResource NullableDoubleConverter}, UpdateSourceTrigger=PropertyChanged}"
                                    Width="80" />
                <DataGridTextColumn Header="Adet"
                                    Binding="{Binding Count, UpdateSourceTrigger=PropertyChanged}"
                                    Width="72" />
                <DataGridTextColumn Header="H (mm)"
                                    Binding="{Binding LengthH_mm, Converter={StaticResource NullableDoubleConverter}, UpdateSourceTrigger=PropertyChanged}"
                                    Width="88" />
                <DataGridTextColumn Header="L (mm)"
                                    Binding="{Binding LengthL_mm, Converter={StaticResource NullableDoubleConverter}, UpdateSourceTrigger=PropertyChanged}"
                                    Width="88" />
                <DataGridTextColumn Header="Çelik"
                                    Binding="{Binding SteelGrade, UpdateSourceTrigger=PropertyChanged}"
                                    Width="64" />
                <DataGridTextColumn Header="kg"
                                    Binding="{Binding TotalWeightKg, Converter={StaticResource NullableDoubleConverter}, UpdateSourceTrigger=PropertyChanged}"
                                    Width="64"
                                    IsReadOnly="True" />
                <DataGridTextColumn Header="Not"
                                    Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*" MinWidth="50" />
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </TabItem>
      </TabControl>
      </Grid>
    </Grid>

    <TextBlock x:Name="StatusText"
               Grid.Row="3"
               Margin="0,4,0,0"
               FontSize="12"
               Foreground="#323232"
               Text="Ürün seçin veya yeni oluşturun." />
  </Grid>
</Window>
