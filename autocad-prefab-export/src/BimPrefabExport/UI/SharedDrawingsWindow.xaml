<Window x:Class="BimPrefabExport.UI.SharedDrawingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Genel ve detay çizimler"
        Height="520"
        Width="920"
        MinHeight="400"
        MinWidth="640"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6F9">
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               TextWrapping="Wrap"
               Margin="0,0,0,10"
               Foreground="#123A5C"
               FontSize="13"
               Text="Projeye ortak çizimler (genel plan, detaylar vb.) ekleyin; her biri için tek bir kapalı polyline sınırı seçilir. PDF’leri ürün paketinden ayrı klasöre alabilirsiniz." />

    <DataGrid x:Name="DrawingsGrid"
              Grid.Row="1"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              CanUserDeleteRows="False"
              HeadersVisibility="Column"
              SelectionMode="Single"
              SelectionUnit="FullRow"
              GridLinesVisibility="Horizontal"
              BorderBrush="#C8D0D8"
              BorderThickness="1"
              Background="White"
              FontSize="13"
              RowHeight="28">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Ad"
                            Binding="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                            Width="2*"
                            MinWidth="120" />
        <DataGridTextColumn Header="Tür (GENEL / DETAY)"
                            Binding="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                            Width="140" />
        <DataGridTextColumn Header="Çit"
                            Binding="{Binding FenceStatus, Mode=OneWay}"
                            Width="52"
                            IsReadOnly="True" />
        <DataGridTextColumn Header="Oluşturma"
                            Binding="{Binding CreatedText, Mode=OneWay}"
                            Width="130"
                            IsReadOnly="True" />
        <DataGridTextColumn Header="Güncelleme"
                            Binding="{Binding ModifiedText, Mode=OneWay}"
                            Width="130"
                            IsReadOnly="True" />
        <DataGridTextColumn Header="PDF kağıt"
                            Binding="{Binding PlotPaperSize, UpdateSourceTrigger=PropertyChanged}"
                            Width="88" />
        <DataGridCheckBoxColumn Header="Yatay"
                                Binding="{Binding PlotLandscape, UpdateSourceTrigger=PropertyChanged}"
                                Width="64" />
      </DataGrid.Columns>
    </DataGrid>

    <TextBlock x:Name="StatusLine"
               Grid.Row="2"
               Margin="0,8,0,0"
               FontSize="12"
               Foreground="#323232"
               Text="" />

    <WrapPanel Grid.Row="3" Margin="0,12,0,0">
      <Button Content="+ Çizim ekle"
              MinWidth="110"
              Margin="0,0,8,8"
              Padding="12,6"
              Click="OnAddDrawing" />
      <Button Content="− Sil"
              MinWidth="88"
              Margin="0,0,8,8"
              Padding="12,6"
              Click="OnRemoveDrawing" />
      <Button Content="Çizim sınırı seç"
              MinWidth="130"
              Margin="0,0,8,8"
              Padding="12,6"
              Click="OnPickFence" />
      <Button Content="Kaydet"
              MinWidth="88"
              Margin="0,0,8,8"
              Padding="12,6"
              Click="OnSave" />
      <Button Content="PDF klasörüne…"
              MinWidth="140"
              Margin="0,0,8,8"
              Padding="12,6"
              Click="OnExportPdfFolder" />
      <Button Content="Kapat"
              MinWidth="88"
              Margin="0,0,0,8"
              Padding="12,6"
              Click="OnClose" />
    </WrapPanel>
  </Grid>
</Window>
